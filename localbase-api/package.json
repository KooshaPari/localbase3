{
	"name": "localbase-api",
	"version": "0.1.0",
	"description": "OpenAI-compatible API gateway for the LocalBase decentralized AI compute marketplace",
	"main": "server.js",
	"scripts": {
		"start": "node server.js",
		"dev": "nodemon server.js",
