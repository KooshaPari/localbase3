		"body-parser": "^1.20.4",
		"cors": "^2.8.5",
		"dotenv": "^16.3.1",
		"express": "^4.22.1",
		"express-rate-limit": "^7.1.5",
		"helmet": "^7.1.0",
		"jsonwebtoken": "^9.0.2",
		"uuid": "^14.0.0"
	},
	"devDependencies": {
		"jest": "^29.7.0",
		"k6": "^0.0.0",
		"nodemon": "^3.0.2",
		"supertest": "^6.3.3"
