# LocalBase API Gateway Environment Variables

# Server configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Authentication configuration
JWT_SECRET=your-jwt-secret-key

# Database configuration
MONGODB_URI=mongodb://localhost:27017/localbase

# Blockchain configuration
BLOCKCHAIN_RPC_URL=http://localhost:26657
BLOCKCHAIN_CHAIN_ID=localbase-1
BLOCKCHAIN_WALLET_MNEMONIC=your-wallet-mnemonic
